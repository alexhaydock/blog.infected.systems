#!/usr/bin/env sh
set -euo pipefail

STATUS_FILE="/srv/www/htdocs/status/index.html"
mkdir -p "$(dirname "$STATUS_FILE")"

# Stop dhcpcd if it's running because disabling it in rc.conf
# didn't seem to work and this is a convenient place to do it
# if we're going to be running this script on a cron every 15min
/etc/rc.d/ntpd onestop || true
/etc/rc.d/dhcpcd onestop || true

{
    echo -e "<html><head></head><body><pre>\n&#10468;&#10468;&#10468;&#10240;&#10240;&#10240;&#10240;&#10240;&#10432;&#10468;&#10436;&#10240;&#10240;&#10240;&#10240;&#10240;&#10464;&#10468;&#10468;&#10240;&#10240;&#10484;&#10495;&#10470;&#10240;&#10240;&#10368;&#10486;&#10495;&#10470;&NewLine;&#10424;&#10495;&#10495;&#10311;&#10240;&#10240;&#10240;&#10400;&#10495;&#10495;&#10495;&#10439;&#10240;&#10240;&#10240;&#10240;&#10495;&#10495;&#10367;&#10240;&#10240;&#10299;&#10495;&#10271;&#10240;&#10240;&#10248;&#10303;&#10495;&#10271;&NewLine;&#10240;&#10431;&#10495;&#10487;&#10240;&#10240;&#10240;&#10492;&#10495;&#10367;&#10495;&#10495;&#10304;&#10240;&#10240;&#10424;&#10495;&#10495;&#10247;&#10240;&#10240;&#10432;&#10432;&#10304;&#10240;&#10240;&#10240;&#10432;&#10432;&#10304;&NewLine;&#10240;&#10296;&#10495;&#10495;&#10310;&#10240;&#10400;&#10495;&#10495;&#10243;&#10431;&#10495;&#10439;&#10240;&#10240;&#10495;&#10495;&#10335;&#10240;&#10240;&#10240;&#10495;&#10495;&#10495;&#10240;&#10240;&#10240;&#10495;&#10495;&#10495;&NewLine;&#10240;&#10240;&#10431;&#10495;&#10487;&#10240;&#10488;&#10495;&#10335;&#10240;&#10264;&#10495;&#10495;&#10240;&#10424;&#10495;&#10495;&#10247;&#10240;&#10240;&#10240;&#10495;&#10495;&#10495;&#10240;&#10240;&#10240;&#10495;&#10495;&#10495;&NewLine;&#10240;&#10240;&#10296;&#10495;&#10495;&#10436;&#10495;&#10495;&#10243;&#10240;&#10240;&#10431;&#10495;&#10439;&#10495;&#10495;&#10367;&#10240;&#10240;&#10240;&#10240;&#10495;&#10495;&#10495;&#10240;&#10240;&#10240;&#10495;&#10495;&#10495;&NewLine;&#10240;&#10240;&#10240;&#10431;&#10495;&#10495;&#10495;&#10335;&#10240;&#10240;&#10240;&#10296;&#10495;&#10495;&#10495;&#10495;&#10243;&#10240;&#10240;&#10240;&#10240;&#10495;&#10495;&#10495;&#10240;&#10240;&#10240;&#10495;&#10495;&#10495;&NewLine;&#10240;&#10240;&#10240;&#10264;&#10431;&#10495;&#10367;&#10241;&#10240;&#10240;&#10240;&#10240;&#10299;&#10495;&#10495;&#10271;&#10240;&#10240;&#10240;&#10240;&#10240;&#10495;&#10495;&#10495;&#10240;&#10240;&#10240;&#10495;&#10495;&#10495;\n\nblog.infected.systems NetBSD Wii Status\nGenerated on: $(date)\n\n=== uname -a ==="
    /usr/bin/uname -a | /usr/bin/fold
    echo -e '\n=== uptime ==='
    /usr/bin/uptime
    echo -e '\n=== bsdfetch ==='
    /usr/pkg/bin/bsdfetch
    echo -e '\n=== vmstat ==='
    /usr/bin/vmstat
    echo -e '\n=== iostat -xz ld0 ==='
    /usr/sbin/iostat -xz ld0
    echo -e '\n=== df -h / ==='
    /bin/df -h /
    echo -e '\n=== top ==='
    /usr/bin/top
    echo -e '</pre></body></html>'
} > "$STATUS_FILE"
